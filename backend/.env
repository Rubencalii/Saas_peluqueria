# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
# Secreto de la app y, además, clave de firma de los JWT del panel (AuthService).
# En producción debe ser un valor aleatorio y secreto (.env.local / variable de entorno).
APP_SECRET=dev-insecure-change-me-32bytes-min-0001
APP_SHARE_DIR=var/share
# URL pública del sitio (para construir enlaces, p. ej. el de reset de contraseña).
APP_URL=http://localhost:8000
# Orígenes permitidos por CORS (lista separada por comas). `*` = cualquiera (dev).
# En producción, fija los dominios del panel y la web: "https://panel.tu-salon.es,https://reservas.tu-salon.es"
CORS_ALLOWED_ORIGINS=*
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL="postgresql://peluqueria:peluqueria@127.0.0.1:5446/peluqueria?serverVersion=16&charset=utf8"
# Para ACTIVAR Row-Level Security (multi-tenant Fase 4): conecta la web como el
# rol restringido `peluqueria_app` (creado por la migración 0017). Las
# migraciones y el cron deben seguir usando el owner `peluqueria` de arriba.
# DATABASE_URL="postgresql://peluqueria_app:peluqueria_app@127.0.0.1:5446/peluqueria?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> whatsapp ###
# Verificación del webhook (handshake de Meta). Debe coincidir con el panel de Meta.
WHATSAPP_VERIFY_TOKEN=peluqueria-verify-token
# Credenciales de la Cloud API. En local se dejan vacías: el bot registra los
# mensajes salientes en el log en lugar de llamar a Meta (ver WhatsAppMessenger).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v21.0
# App secret de Meta para verificar la firma del webhook (X-Hub-Signature-256).
# Vacío en local: no se exige firma. En producción debe estar configurado.
WHATSAPP_APP_SECRET=
###< whatsapp ###

###> anthropic ###
# IA conversacional del bot (AiAssistant). Sin clave, el bot funciona solo con
# botones (la IA se desactiva). Con clave, entiende lenguaje natural.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
###< anthropic ###

###> stripe ###
# Depósito/pago online (PaymentService). Sin clave, los pagos se desactivan.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Suscripción del SaaS (BillingService, multi-tenant Fase 5). Webhook propio
# (customer.subscription.*, invoice.*). Reutiliza STRIPE_SECRET_KEY.
STRIPE_BILLING_WEBHOOK_SECRET=
###< stripe ###

###> symfony/mailer ###
# Transporte de email. `null://null` = desactivado (los emails se registran en el
# log, modo desarrollo). En producción, un DSN SMTP/Resend/etc.
MAILER_DSN=null://null
# Remitente de los correos salientes.
MAILER_FROM=no-reply@salon.es
###< symfony/mailer ###
