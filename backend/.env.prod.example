# Plantilla de configuración de PRODUCCIÓN.
# Copia los valores como variables de entorno reales del servidor / gestor de
# secretos. NO comitees el archivo con los valores rellenos.

APP_ENV=prod
APP_DEBUG=0

# OBLIGATORIO: secreto único y aleatorio de >=32 caracteres. Sin esto, los JWT
# son forjables. Genera uno, p. ej.:  php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=__CAMBIA_ESTO_por_un_valor_aleatorio_de_32+_caracteres__

APP_URL=https://reservas.tu-dominio.com

# Bloquea CORS a los dominios reales del panel y la web pública.
CORS_ALLOWED_ORIGINS=https://panel.tu-dominio.com,https://reservas.tu-dominio.com

# Proxies de confianza (IP/rango del balanceador) para que el rate limiting use
# la IP real del cliente.
TRUSTED_PROXIES=127.0.0.1

# Base de datos: conecta como el rol RESTRINGIDO para ACTIVAR Row-Level Security
# (la app no debe conectar como owner en prod). Las migraciones y el cron sí
# usan el owner.
DATABASE_URL="postgresql://peluqueria_app:CONTRASEÑA@HOST:5432/peluqueria?serverVersion=16&charset=utf8"

# WhatsApp (si se usa el bot): con secreto, el webhook EXIGE firma (en prod, sin
# secreto el webhook se rechaza).
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Stripe (depósitos y suscripción del SaaS). Sin claves, esos pagos se desactivan.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BILLING_WEBHOOK_SECRET=

# IA del bot (opcional).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Email.
MAILER_DSN=
MAILER_FROM=
