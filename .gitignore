.env.*.local
backend/.env.local
backend/.env.*.local

# Dependencias y artefactos generados
/backend/vendor/
/backend/var/
/backend/public/bundles/
node_modules/

# Datos de Postgres si alguien monta el volumen como carpeta
/db/pgdata/

# Archivos del sistema operativo
.DS_Store
Thumbs.db
desktop.ini
*~

# Producción (compose): secretos y copias de seguridad locales
/.env
backend/.env.prod
/backups/
